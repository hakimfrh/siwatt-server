DB_HOST=localhost
DB_USER=root
DB_PASS=
DB_NAME=siwatt_final

JWT_SECRET=siwatt_super_secret_123
JWT_EXPIRE_MINUTES=1440

MJ_APIKEY_PUBLIC=isi_public_key_kamu
MJ_APIKEY_PRIVATE=isi_secret_key_kamu
MAILJET_SENDER_EMAIL=noreply@domainkamu.com

MQTT_BROKER=your.mqtt.broker
MQTT_PORT=1883
MQTT_CLIENT_ID=siwatt-worker
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_TOPIC_WILDCARD=/siwatt/+/raw/+
MQTT_TOPIC_MODE=prefixed

BALANCE_DECREASE_MODE=minute

TESTING_API_SECRET=siwatt-testing-api-secret

ML_POLL_INTERVAL_SECONDS=60
ML_MAX_JOBS_PER_CYCLE=20
ML_PREDICTIONS_TABLE=predictions
ML_HOURLY_MODEL_PATH=ml_worker/models/siwatt_lstm_hour-lag168_v2.2.keras
ML_DAILY_MODEL_PATH=ml_worker/models/siwatt_lstm_day_v1.3.keras
ML_DEFAULT_HISTORY_HOURS=2880
ML_DEFAULT_HORIZON_HOURLY=24
ML_DEFAULT_HORIZON_DAILY=14
ML_DEFAULT_FILL_METHOD=smart_fill
ML_DEFAULT_SMART_FILL_WEEKS=6
ML_DEFAULT_ALLOW_PARTIAL_DAILY=false

ML_ENABLE_RETRAIN=true
ML_RETRAIN_INTERVAL_DAYS=30
ML_RETRAIN_HISTORY_DAYS=365
ML_RETRAIN_MODEL_TYPES=hourly,daily
ML_RETRAIN_OUTPUT_DIR=ml_worker/models/retrained
ML_TRAIN_LOG_TABLE=train_log
# kosong = retrain semua device (per-device series, bukan agregasi)
ML_RETRAIN_DEVICE_ID=
ML_RETRAIN_HOURLY_EPOCHS=100
ML_RETRAIN_DAILY_EPOCHS=200
ML_RETRAIN_HOURLY_PATIENCE=10
ML_RETRAIN_DAILY_PATIENCE=15
ML_RETRAIN_BATCH_SIZE=16
# device dengan data hourly < nilai ini akan di-skip saat retrain hourly
ML_RETRAIN_MIN_HOURLY_ROWS=720
# untuk retrain daily, ambang harian per device (fitur lag tetap butuh data lebih banyak)
ML_RETRAIN_MIN_DAILY_ROWS=90
